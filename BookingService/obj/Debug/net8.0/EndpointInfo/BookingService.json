{
  "openapi": "3.0.1",
  "info": {
    "title": "BookingService",
    "version": "1.0"
  },
  "paths": {
    "/api/booking": {
      "post": {
        "tags": [
          "Booking"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBookingDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBookingDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBookingDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "get": {
        "tags": [
          "Booking"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateBookingDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "format": "int32"
          },
          "flightId": {
            "type": "integer",
            "format": "int32"
          },
          "passengers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PassengerDto"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PassengerDto": {
        "type": "object",
        "properties": {
          "passengerName": {
            "type": "string",
            "nullable": true
          },
          "age": {
            "type": "integer",
            "format": "int32"
          },
          "gender": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}